{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "B2",
  "version": "0.1.0",
  "identifier": "dev.b2.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../../ui"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../../ui"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "B2",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
